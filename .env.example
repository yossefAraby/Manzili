# Copy to .env.local and fill in. Do not commit .env.local.

NEXT_PUBLIC_CURRENCY_SYMBOL=EGP
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — use test keys from Dashboard → Developers → API keys (sk_test_ / pk_test_)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe webhook (optional, but required for server-trusted payment confirmation)
STRIPE_WEBHOOK_SECRET=
# Server-side checkout currency (set this in Vercel)
STRIPE_CURRENCY=egp
# Optional client override for display code
NEXT_PUBLIC_STRIPE_CURRENCY=egp

# Optional
# NODE_OPTIONS=--max-old-space-size=4096

# Bosta (Master Account)
# Enable integration and provide Authorization header value (per spec security scheme).
BOSTA_INTEGRATION_ENABLED=false
BOSTA_BASE_URL=https://app.bosta.co/api/v2/
BOSTA_AUTHORIZATION=
# Optional convenience: if you have only API key, set this instead of BOSTA_AUTHORIZATION.
BOSTA_API_KEY=
# Optional: set auth scheme prefix if your account requires one (e.g., Bearer/ApiKey).
BOSTA_AUTH_SCHEME=
# Default pickup location id to use when store has no bostaPickupLocationId
BOSTA_BUSINESS_LOCATION_ID_DEFAULT=
# Webhook target base URL (route path /api/webhooks/bosta is appended automatically)
BOSTA_WEBHOOK_BASE_URL=http://localhost:3000
# Protect webhook receiver (legacy: checks Authorization header)
BOSTA_WEBHOOK_AUTH=
# Preferred custom webhook header validation:
BOSTA_WEBHOOK_AUTH_HEADER_NAME=
BOSTA_WEBHOOK_AUTH_HEADER_VALUE=

# Admin actions (manual COD settlement release)
ADMIN_ACTIONS_SECRET=

# Local dev: passkey for /admin (URL gate; no login). Defaults to "admin" if unset.
# NEXT_PUBLIC_ADMIN_PASSKEY=admin

# Cart estimated shipping (EGP). Server + optional public overrides for client display.
ESTIMATE_SHIP_SMALL=35
ESTIMATE_SHIP_MEDIUM=50
ESTIMATE_SHIP_LARGE=75
NEXT_PUBLIC_ESTIMATE_SHIP_SMALL=35
NEXT_PUBLIC_ESTIMATE_SHIP_MEDIUM=50
NEXT_PUBLIC_ESTIMATE_SHIP_LARGE=75

# Map internal SMALL|MEDIUM|LARGE → Bosta create-delivery specs.size (per account/environment)
# BOSTA_SIZE_MAP_SMALL=SMALL
# BOSTA_SIZE_MAP_MEDIUM=MEDIUM
# BOSTA_SIZE_MAP_LARGE=LARGE

# Map internal NORMAL|LIGHT_BULKY|HEAVY_BULKY → Bosta package type string
# BOSTA_BULKY_MAP_NORMAL=Normal
# BOSTA_BULKY_MAP_LIGHT_BULKY=Light Bulky
# BOSTA_BULKY_MAP_HEAVY_BULKY=Heavy Bulky
